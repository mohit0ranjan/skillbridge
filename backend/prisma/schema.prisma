generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  password        String
  college         String?
  year            String?
  role            Role      @default(USER)
  tokenVersion    Int       @default(0)
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  internships          UserInternship[]
  submissions          Submission[]
  finalSubmissions     FinalProjectSubmission[]
  certificates         Certificate[]
  payments             Payment[]
  tickets              Ticket[]
  internProfile        InternProfile?
  workspaceProgress    WorkspaceProgress?
  workspaceSubmissions WorkspaceSubmission[]
  screeningSubmission  ScreeningSubmission?

  @@index([email])
  @@index([role])
}

model WorkspaceProject {
  id          String   @id @default(uuid())
  title       String
  difficulty  WorkspaceProjectDifficulty
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  internProfiles       InternProfile[]
  workspaceSubmissions WorkspaceSubmission[]

  @@index([difficulty])
}

model InternProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  selectedProjectId String?
  internshipStart   DateTime?
  internshipEnd     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedProject WorkspaceProject? @relation(fields: [selectedProjectId], references: [id], onDelete: SetNull)

  @@index([selectedProjectId])
}

model WorkspaceProgress {
  id        String   @id @default(uuid())
  userId    String   @unique
  week1     Boolean  @default(false)
  week2     Boolean  @default(false)
  week3     Boolean  @default(false)
  week4     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkspaceSubmission {
  id          String                    @id @default(uuid())
  userId      String
  projectId   String
  githubLink  String
  status      WorkspaceSubmissionStatus @default(PENDING)
  feedback    String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project WorkspaceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([status])
}

model Internship {
  id          String   @id @default(uuid())
  title       String
  domain      String
  duration    String
  level       String
  price       Int      @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks            Task[]
  userInternships  UserInternship[]
  finalSubmissions FinalProjectSubmission[]
  certificates     Certificate[]
  payments         Payment[]

  @@index([domain])
}

model Task {
  id           String   @id @default(uuid())
  internshipId String
  title        String
  description  String
  week         Int
  resources    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  internship  Internship   @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([internshipId])
}

model UserInternship {
  id             String               @id @default(uuid())
  userId         String
  internshipId   String
  status         UserInternshipStatus @default(STARTED)
  progress       Int                  @default(0)
  completedWeeks Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@unique([userId, internshipId])
  @@index([userId])
  @@index([internshipId])
}

model FinalProjectSubmission {
  id           String                  @id @default(uuid())
  userId       String
  internshipId String
  projectTitle String
  projectLink  String
  description  String
  fileUrl      String?
  status       ProjectSubmissionStatus @default(SUBMITTED)
  feedback     String?
  submittedAt  DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@unique([userId, internshipId])
  @@index([userId])
  @@index([internshipId])
  @@index([status])
}

model Submission {
  id         String           @id @default(uuid())
  userId     String
  taskId     String
  githubLink String
  status     SubmissionStatus @default(SUBMITTED)
  feedback   String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([userId])
  @@index([status])
}

model Certificate {
  id            String   @id @default(uuid())
  userId        String
  internshipId  String
  certificateId String   @unique
  issuedDate    DateTime @default(now())
  isPaid        Boolean  @default(false)
  updatedAt     DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@unique([userId, internshipId])
  @@index([userId])
  @@index([internshipId])
  @@index([certificateId])
  @@index([isPaid])
}

model Payment {
  id                String        @id @default(uuid())
  userId            String
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  razorpayId        String?       @unique
  razorpayOrderId   String?       @unique
  razorpaySignature String?
  certificateId     String?
  internshipId      String?
  idempotencyKey    String?       @unique
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificate Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)
  internship  Internship?  @relation(fields: [internshipId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([internshipId])
  @@index([certificateId])
  @@index([razorpayOrderId])
  @@index([status])
}

model Ticket {
  id        String       @id @default(uuid())
  userId    String
  subject   String
  message   String
  status    TicketStatus @default(OPEN)
  replyMessage String?
  repliedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ────────────────────────────────────────────────
// SCREENING PIPELINE
// ────────────────────────────────────────────────

model ScreeningSubmission {
  id         String          @id @default(uuid())
  userId     String          @unique
  answers    Json
  score      Float?
  status     ScreeningStatus @default(SUBMITTED)
  feedback   String?
  reviewedBy String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ────────────────────────────────────────────────
// AUDIT LOG
// ────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  targetId  String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

// ENUMS

enum Role {
  USER
  ADMIN
  INTERN
}

enum ScreeningStatus {
  SUBMITTED
  UNDER_REVIEW
  SELECTED
  REJECTED
}

enum WorkspaceProjectDifficulty {
  EASY
  MEDIUM
  HARD
}

enum WorkspaceSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserInternshipStatus {
  STARTED
  IN_PROGRESS
  COMPLETED
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum ProjectSubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  REVIEWED
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
