# Prisma DB
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth
JWT_SECRET="your_jwt_secret_here"
JWT_RESET_SECRET="your_jwt_reset_secret_here"
JWT_VERIFY_EMAIL_SECRET="your_jwt_verify_email_secret_here"

# Frontend
FRONTEND_URL=http://localhost:3000

# Razorpay (fill with real keys for production)
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
# Webhook — must match the secret you set in Razorpay Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# Email (Zoho SMTP)
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_USER=noreply@skillbridge.co.in
SMTP_PASS=your_smtp_pass
