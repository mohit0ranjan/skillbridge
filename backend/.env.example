# ═══════════════════════════════════════════════════════════
# SkillBridge API — Environment Variables
# Copy this file to .env and fill in real values
# ═══════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Azure sets PORT automatically — do NOT hardcode in production

# ── Database (Neon PostgreSQL) ─────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Auth (JWT) — each secret MUST be unique ────────────────
JWT_SECRET="your_super_secret_jwt_key_min_32_chars"
JWT_RESET_SECRET="your_password_reset_secret_min_32_chars"
JWT_VERIFY_EMAIL_SECRET="your_email_verification_secret_min_32_chars"

# ── Frontend URL ───────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production example: https://skillbridge.co.in
# Multiple origins (comma-separated): https://skillbridge.co.in,https://www.skillbridge.co.in
APP_URL=http://localhost:3000

# ── Backend URL (public API base) ─────────────────────────
# BACKEND_URL=https://your-app.azurewebsites.net

# ── Email (Zoho SMTP) ─────────────────────────────────────
SMTP_HOST=smtp.zoho.in
SMTP_PORT=587
SMTP_USER=noreply@skillbridge.co.in
SMTP_PASS=your_zoho_app_password
# Support email shown in templates:
# EMAIL_SUPPORT=support@skillbridge.co.in
# SUPPORT_EMAIL=support@skillbridge.co.in
# CONTACT_EMAIL=support@skillbridge.co.in

# ── Razorpay Payment Gateway ─────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
# RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"
# RAZORPAY_MODE=test
# RAZORPAY_KEY_ID_TEST="rzp_test_xxxxxxxxxxxx"
# RAZORPAY_KEY_SECRET_TEST="your_test_secret"
# RAZORPAY_KEY_ID_LIVE="rzp_live_xxxxxxxxxxxx"
# RAZORPAY_KEY_SECRET_LIVE="your_live_secret"
# For live: set RAZORPAY_KEY_ID_LIVE and RAZORPAY_KEY_SECRET_LIVE

# ── Prisma Accelerate (optional) ─────────────────────────
# ACCELERATE_URL="prisma://accelerate.prisma-data.net/?api_key=..."
